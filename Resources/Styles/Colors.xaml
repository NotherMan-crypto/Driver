<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Primary Colors -->
    <Color x:Key="Primary">#2563EB</Color>
    <Color x:Key="PrimaryDark">#1D4ED8</Color>
    <Color x:Key="PrimaryLight">#DBEAFE</Color>
    <Color x:Key="PrimaryLighter">#EFF6FF</Color>

    <!-- Semantic Colors -->
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="SuccessLight">#D1FAE5</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="WarningLight">#FEF3C7</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="DangerLight">#FEE2E2</Color>

    <!-- Neutral Colors -->
    <Color x:Key="TextPrimary">#0F172A</Color>
    <Color x:Key="TextSecondary">#64748B</Color>
    <Color x:Key="TextMuted">#94A3B8</Color>
    <Color x:Key="Border">#E2E8F0</Color>
    <Color x:Key="BorderLight">#F1F5F9</Color>
    <Color x:Key="Background">#F8FAFC</Color>
    <Color x:Key="Surface">#FFFFFF</Color>

    <!-- Question Navigator Colors -->
    <Color x:Key="Unanswered">#CBD5E1</Color>
    <Color x:Key="Answered">#3B82F6</Color>

    <!-- Light/Dark Theme Colors -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="Gray100">#F1F5F9</Color>
    <Color x:Key="Gray200">#E2E8F0</Color>
    <Color x:Key="Gray300">#CBD5E1</Color>
    <Color x:Key="Gray400">#94A3B8</Color>
    <Color x:Key="Gray500">#64748B</Color>
    <Color x:Key="Gray600">#475569</Color>
    <Color x:Key="Gray700">#334155</Color>
    <Color x:Key="Gray800">#1E293B</Color>
    <Color x:Key="Gray900">#0F172A</Color>

</ResourceDictionary>
